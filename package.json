{
  "name": "gonkulator",
  "version": "1.0.0",
  "description": "A 1990's style scientific calculator webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check && npm run typecheck && vite build",
    "preview": "vite preview",
    "check": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0"
  }
}
